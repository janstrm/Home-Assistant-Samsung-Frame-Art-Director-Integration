{
  "domain": "samsung_frame_art_director",
  "name": "Samsung Frame Art Director",
  "after_dependencies": ["wake_on_lan"],
  "codeowners": [
    "@janstrm"
  ],
  "config_flow": true,
  "dependencies": ["http", "media_source"],
  "dhcp": [
    {
      "hostname": "samsung*"
    }
  ],
  "documentation": "https://github.com/janstrm/Home-Assistant-Samsung-Frame-Art-Director-Integration",
  "iot_class": "local_polling",
  "issue_tracker": "https://github.com/janstrm/Home-Assistant-Samsung-Frame-Art-Director-Integration/issues",
  "loggers": [
    "samsungtvws"
  ],
  "requirements": [
    "samsungtvws[async,encrypted]>=3.0.5"
  ],
  "version": "1.10.0",
  "zeroconf": [
    "_samsungmsf._tcp.local."
  ]
}
